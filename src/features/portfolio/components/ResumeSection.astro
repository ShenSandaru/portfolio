<section class="resume-section" id="resume">
  <div class="container">
    <div class="resume-card reveal">
      <div class="resume-content">
        <span class="section-tag glow-tag">Curriculum Vitae</span>
        <h2>Interested in working together or learning more?</h2>
        <p>
          Download my updated resume or view my credentials. The full resume link will be available soon.
        </p>
        <div class="resume-actions">
          <a href="#" class="btn btn-resume-disabled" onclick="event.preventDefault(); alert('Resume URL will be updated soon!');"
            ><i class="fas fa-file-pdf"></i> Resume Coming Soon</a
          >
          <a href="#contact" class="btn btn-resume-outline"
            ><i class="fas fa-paper-plane"></i> Contact Me</a
          >
        </div>
      </div>
      <div class="resume-badge-icon">
        <i class="fas fa-file-alt"></i>
      </div>
    </div>
  </div>
</section>

<style>
  .resume-section {
    padding: 100px 0;
    position: relative;
    z-index: 2;
  }

  .resume-card {
    background: linear-gradient(135deg, #111116 0%, #1a1a24 50%, #0d0d12 100%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 24px;
    padding: 60px 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
    overflow: hidden;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
    transform: translateY(30px) scale(0.97);
    opacity: 0;
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .resume-card.visible {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  .resume-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, #2563eb, #60a5fa, #1d4ed8);
  }

  .resume-card::after {
    content: "";
    position: absolute;
    top: -50%;
    right: -20%;
    width: 350px;
    height: 350px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(37, 99, 235, 0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  .resume-content {
    max-width: 650px;
    position: relative;
    z-index: 2;
  }

  .glow-tag {
    color: #60a5fa !important;
    letter-spacing: 3px;
    font-weight: 700;
  }

  .glow-tag::before,
  .glow-tag::after {
    background: #60a5fa !important;
  }

  .resume-content h2 {
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    color: #ffffff;
    font-weight: 800;
    margin: 12px 0 16px;
    line-height: 1.25;
  }

  .resume-content p {
    color: #94a3b8;
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 32px;
  }

  .resume-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn-resume-disabled {
    background: linear-gradient(135deg, #2563eb, #1d4ed8);
    color: #ffffff;
    box-shadow: 0 4px 20px rgba(37, 99, 235, 0.3);
    cursor: pointer;
  }

  .btn-resume-disabled:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(37, 99, 235, 0.4);
  }

  .btn-resume-outline {
    background: rgba(255, 255, 255, 0.05);
    color: #f1f5f9;
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  .btn-resume-outline:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #ffffff;
    border-color: #60a5fa;
    transform: translateY(-3px);
  }

  .resume-badge-icon {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #60a5fa;
    font-size: 3.5rem;
    position: relative;
    z-index: 2;
    box-shadow: inset 0 0 30px rgba(37, 99, 235, 0.1);
  }

  @media (max-width: 868px) {
    .resume-card {
      flex-direction: column;
      text-align: center;
      padding: 40px 24px;
      gap: 32px;
    }
    .resume-actions {
      justify-content: center;
    }
    .resume-badge-icon {
      width: 100px;
      height: 100px;
      font-size: 2.5rem;
    }
  }
</style>
