---
import type { HeroContent } from "../domain/portfolio.types";

interface Props {
  content: HeroContent;
}

const { content } = Astro.props;
---

<section class="hero" id="hero">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-content">
        <div class="hero-badge reveal">
          <span class="dot"></span>
          {content.badge}
        </div>
        <h1 class="reveal">
          Hi, I'm <span class="gradient-text">{content.titleName}</span><br />
          Full-Stack <span class="gradient-text">{content.titleRole}</span>
        </h1>
        <div class="typing-wrapper reveal">
          <span id="typingText"></span>
          <span class="typing-cursor"></span>
        </div>
        {content.intro && <p class="reveal">{content.intro}</p>}
        <div class="hero-buttons reveal">
          <a href={content.ctaPrimaryHref} class="btn btn-primary"
            ><i class="fas fa-rocket"></i> {content.ctaPrimaryLabel}</a
          >
          <a href={content.ctaSecondaryHref} class="btn btn-outline"
            ><i class="fas fa-paper-plane"></i> {content.ctaSecondaryLabel}</a
          >
        </div>
        <div class="hero-stats reveal">
          {
            content.stats.map((stat) => (
              <div class="stat">
                <h3>{stat.value}</h3>
                <p>{stat.label}</p>
              </div>
            ))
          }
        </div>
      </div>
      <div class="hero-visual reveal">
        <div class="profile-ring">
          <div class="profile-placeholder">
            <i class="fas fa-code"></i>
          </div>
        </div>
        <div class="floating-badge badge-1">
          <i class="fas fa-bolt"></i> {content.badges[0]}
        </div>
        <div class="floating-badge badge-2">
          <i class="fas fa-paint-brush"></i> {content.badges[1]}
        </div>
        <div class="floating-badge badge-3">
          <i class="fas fa-mobile-alt"></i> {content.badges[2]}
        </div>
      </div>
    </div>
  </div>
</section>
